FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    swtpm \
    tpm2-tools \
    tpm2-openssl \
    openssl \
    python3 \
    python3-pip \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /project

# Install Python deps at build time so they are cached in the image layer.
# The source tree is mounted at runtime — rebuild the image only when
# requirements.txt or requirements-test.txt change.
COPY requirements.txt requirements-test.txt ./
RUN pip3 install --no-cache-dir -r requirements.txt -r requirements-test.txt

CMD ["python3", "-m", "pytest", "tests/", "-v"]
